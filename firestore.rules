rules_version = '2';

// Lionstack — Firestore rules
//
// Everything the back office stores lives in ONE collection, `appdata`, with a
// document per storage key. Two audiences:
//   • staff  — signed in, may read and write everything
//   • public — the storefront (shop.html), not signed in, may read ONLY the
//              handful of documents needed to render the shop
//
// Paste this into Firebase console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    match /appdata/{key} {
      // The storefront reads these without signing in.
      allow read: if request.auth != null
                  || key in [
                       'mod_storefront_published',
                       'mod_storefront_config',
                       'mod_store_products',
                       'mod_store_config',
                       'mod_store_promotions',
                       'mod_store_stockpublic'
                     ];

      // Only a signed-in user may change anything.
      allow write: if request.auth != null;
    }

    // Anything not named above is closed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
